{
  "name": "stash",
  "version": "0.1.10",
  "private": true,
  "description": "Todo + Agent Workboard — Inbox-first task capture with Claude/Codex session evidence",
  "type": "module",
  "scripts": {
    "server:dev": "bun --watch run server/src/index.ts",
    "server:start": "bun run server/src/index.ts",
    "server:test": "cd server && bun test",
    "server:typecheck": "cd server && bun x tsc --noEmit",
    "client:dev": "cd client && bun run dev",
    "client:build": "cd client && bun run build",
    "client:test": "cd client && bun run test",
    "client:e2e": "cd client && bun run e2e",
    "client:typecheck": "cd client && bun x tsc --noEmit",
    "typecheck": "bun run server:typecheck && bun run client:typecheck",
    "test:all": "bun run server:test && bun run client:test",
    "seed": "bun run server/fixtures/seed.ts",
    "seed:rich": "bun run server/fixtures/seed-rich.ts",
    "seed:rich:sessions": "bun run server/fixtures/seed-rich.ts --with-sessions"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
